// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("STUDENT")
  avatarUrl    String?
  createdAt    DateTime @default(now())

  classes        Membership[]
  taughtClasses  Class[]
  submissions    Submission[]
  reviews        Review[]
  notifications  Notification[]
  communityPosts CommunityPost[]
}

model Class {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  teacherId String
  teacher   User     @relation(fields: [teacherId], references: [id])
  createdAt DateTime @default(now())

  memberships Membership[]
  assignments Assignment[]
}

model Membership {
  id        String   @id @default(cuid())
  classId   String
  studentId String
  joinedAt  DateTime @default(now())

  class   Class @relation(fields: [classId], references: [id])
  student User  @relation(fields: [studentId], references: [id])

  @@unique([classId, studentId])
}

model LibraryItem {
  id        String   @id @default(cuid())
  title     String
  content   String
  tags      String // JSON array
  level     String
  type      String   @default("READING") // READING | INTEGRATION
  createdAt DateTime @default(now())

  assignments Assignment[]
}

model Assignment {
  id            String    @id @default(cuid())
  classId       String
  libraryItemId String
  type          String
  mode          String    @default("INDIVIDUAL")
  dueAt         DateTime?
  createdBy     String
  createdAt     DateTime  @default(now())
  title         String?
  description   String?

  class       Class       @relation(fields: [classId], references: [id])
  libraryItem LibraryItem @relation(fields: [libraryItemId], references: [id])
  submissions Submission[]
}

model Submission {
  id                 String   @id @default(cuid())
  assignmentId       String
  studentId          String
  status             String   @default("DRAFT")
  readingAnswersJson String?
  integrationFileId  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  assignment      Assignment    @relation(fields: [assignmentId], references: [id])
  student         User          @relation(fields: [studentId], references: [id])
  review          Review?
  communityPost   CommunityPost?
  integrationFile UploadedFile? @relation(fields: [integrationFileId], references: [id])
}

model Review {
  id                   String   @id @default(cuid())
  submissionId         String   @unique
  teacherId            String
  perQuestionMarksJson String?
  comment              String?
  resultStatus         String
  reviewedAt           DateTime @default(now())

  submission Submission @relation(fields: [submissionId], references: [id])
  teacher    User       @relation(fields: [teacherId], references: [id])
}

model CommunityPost {
  id           String   @id @default(cuid())
  communityKey String
  submissionId String   @unique
  publishedBy  String
  publishedAt  DateTime @default(now())

  submission Submission @relation(fields: [submissionId], references: [id])
  publisher  User       @relation(fields: [publishedBy], references: [id])
}

model Notification {
  id          String    @id @default(cuid())
  userId      String
  type        String
  payloadJson String
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Rubric {
  id        String @id @default(cuid())
  name      String
  rulesJson String
  threshold Float
  scope     String
}

model UploadedFile {
  id        String   @id @default(cuid())
  filename  String
  mimetype  String
  size      Int
  url       String
  createdAt DateTime @default(now())

  submissions Submission[]
}
